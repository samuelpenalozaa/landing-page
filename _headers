/*
  # Configuración por defecto de seguridad
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff

/css/*
  # Caché larga para CSS estático
  Cache-Control: public, max-age=31536000, immutable

/js/*
  # Caché larga para JS estático
  Cache-Control: public, max-age=31536000, immutable

/img/*
  # Caché larga para imágenes estáticas
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  # Caché larga para assets estáticos
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=31536000, immutable
/favicon-96.png
  Cache-Control: public, max-age=31536000, immutable
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
/og-image.png
  Cache-Control: public, max-age=31536000, immutable
/noise.png
  Cache-Control: public, max-age=31536000, immutable
